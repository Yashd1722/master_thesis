# ----------------------------
# DATASET RULES
# ----------------------------
# Ignore everything in dataset/ ...
dataset/**

# ... but allow the dataset folder structure itself
!dataset/
!dataset/**/

# Allow only the cleaned pangaea CSVs (required for the code)
!dataset/pangaea_923197/datasets/clean_dataset/
!dataset/pangaea_923197/datasets/clean_dataset/*.csv
!dataset/pangaea_923197/datasets/clean_dataset/**/*.csv

# ----------------------------
# TRACK RESULTS AND TEST OUTPUTS
# ----------------------------
!results/
!results/**/*
!test_results/
!test_results/**/*
